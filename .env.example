# 인스타그램 API 토큰 (필수)
INSTAGRAM_ACCESS_TOKEN=your_token_here

# [디자인 커스텀] ----------------------------------------------
# 아래 값들의 주석(#)을 해제하고 원하는 값으로 변경하세요.

# 1. 앱 이름 및 핵심 이모지 변경 (로고, 탭 제목, 버튼 이모지 변경)
APP_BRANDING_NAME=나만의_브랜드
# APP_EMOJI=🎁
# APP_EMOJI=""

# 2. UI 컬러 테마 변경 (앱 전체 색상 변경)
# --- 테마 프리셋 모음 ---
# [기본 테마: 유앤쥬 핑크]
# APP_PRIMARY_COLOR=#FFB7C5
# APP_HOVER_COLOR=#FFA7B5
# APP_BG_COLOR=#FFF9F9

# [추천 테마: 쿨 블루]
# APP_PRIMARY_COLOR=#4A90E2
# APP_HOVER_COLOR=#357ABD
# APP_BG_COLOR=#F5F7FA

# [추천 테마: 다크 모드 감성]
